#!/bin/sh

brew bundle --file=- <<EOF
tap "buo/cask-upgrade"

cask "a-better-finder-rename"
cask "docker"
cask "ferdium"
cask "firefox"
cask "google-chrome"
cask "intellij-idea"
cask "iterm2"
cask "microsoft-edge"
cask "microsoft-office"
cask "nextcloud"
cask "rectangle"
cask "syncthing"
cask "the-unarchiver"
cask "visual-studio-code"
EOF

fancy_echo "Cleaning up old Homebrew formulae ..."
brew cleanup

if [ -r "$HOME/.rcrc" ]; then
  fancy_echo "Updating dotfiles ..."
  rcup
fi
